# ============================================
# sokoe-web 環境変数テンプレート
# 使い方：このファイルを .env.local にコピーして値を埋める
# ============================================

# Site URL (本番URL)
NEXT_PUBLIC_SITE_URL=https://sokoe.co.jp

# ----------------------------------------
# Analytics
# ----------------------------------------

# Google Analytics 4
NEXT_PUBLIC_GA_ID=

# Microsoft Clarity (heatmap, 無料)
NEXT_PUBLIC_CLARITY_ID=

# ----------------------------------------
# Calendly (無料相談予約)
# ----------------------------------------
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/sokoe/30min

# ----------------------------------------
# Resend (メール送信 API)
# ----------------------------------------
RESEND_API_KEY=
CONTACT_EMAIL_TO=info@sokoe.co.jp
CONTACT_EMAIL_FROM=noreply@sokoe.co.jp

# ----------------------------------------
# HubSpot (CRM, 任意)
# ----------------------------------------
HUBSPOT_API_KEY=
HUBSPOT_PORTAL_ID=
